import requests

def buscar_repositorios_github(topico):
    url = "https://api.github.com/search/repositories"
    
    params = {
        'q': topico,
        'sort': 'stars',
        'order': 'desc',
        'per_page': 5  
    }

    try:
        resposta = requests.get(url, params=params, timeout=15)
        resposta.raise_for_status()
        
        dados = resposta.json()
        repositorios = dados.get('items', [])

        
        for i, repo in enumerate(repositorios, 1):
            nome = repo['full_name']
            url_repo = repo['html_url']
            
            print(f"{i}. {nome}")
            print(f"   URL: {url_repo}\n")

    except requests.exceptions.RequestException as e:
        print(f"Erro na conexão: {e}")
    except Exception as e:
        print(f"Erro: {e}")

buscar_repositorios_github("data science")